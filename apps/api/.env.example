# API (Hono)
PORT=3002
NODE_ENV=development

# Auth (los lee @rep/auth; en dev pueden vivir en packages/auth/.env)
# BETTER_AUTH_SECRET=generar con: openssl rand -base64 32
# BETTER_AUTH_URL=http://localhost:3002
# TRUSTED_ORIGINS=http://localhost:3000,http://localhost:3001

# Feature flags
# MODULE_CACHE_TTL_MS=60000

# IA (los lee @rep/ai). Sin ANTHROPIC_API_KEY la IA queda deshabilitada.
# Todas las tareas de IA usan Haiku por defecto.
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-haiku-4-5-20251001
