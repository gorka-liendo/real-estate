# Almacenamiento de archivos. Driver por defecto: local (filesystem, sin credenciales).
STORAGE_DRIVER=local
STORAGE_LOCAL_DIR=.uploads
STORAGE_PUBLIC_URL=http://localhost:3002/uploads

# Producción — Cloudflare R2 (STORAGE_DRIVER=r2):
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET=
# R2_PUBLIC_URL=https://cdn.tudominio.com
