{
  "name": "real-estate-platform",
  "private": true,
  "packageManager": "pnpm@11.13.1",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "predev": "bash scripts/dev-clean.sh",
    "dev": "turbo dev --concurrency=20",
    "predev:up": "bash scripts/dev-clean.sh",
    "dev:up": "docker compose up -d && turbo dev --concurrency=20",
    "dev:clean": "bash scripts/dev-clean.sh",
    "infra:up": "docker compose up -d",
    "infra:down": "docker compose down",
    "build": "turbo build",
    "lint": "turbo lint",
    "test": "turbo test",
    "format": "prettier --write \"**/*.{ts,tsx,md,json}\""
  },
  "devDependencies": {
    "prettier": "^3.6.0",
    "turbo": "^2.5.0",
    "typescript": "^5.9.0"
  }
}
